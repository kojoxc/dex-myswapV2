# RPC URL for the blockchain node (required)
# Default points to local Anvil instance
VITE_RPC_URL=http://127.0.0.1:8545

# Router contract address (optional — uses deployment config if available)
VITE_ROUTER_ADDRESS=

# Default token addresses for the swap input/output (optional)
VITE_TOKEN_IN_ADDRESS=
VITE_TOKEN_OUT_ADDRESS=

# WETH contract address (optional — auto-detected from deployment config)
VITE_WETH_ADDRESS=

# WalletConnect Project ID (optional — required for WalletConnect connections)
# Get one for free at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# External token list URL (optional — Uniswap-compatible token list JSON)
# Example: https://tokens.uniswap.org/
VITE_TOKEN_LIST_URL=
