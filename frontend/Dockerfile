ARG VITE_RPC_URL
ARG VITE_ROUTER_ADDRESS
ARG VITE_TOKEN_IN_ADDRESS
ARG VITE_TOKEN_OUT_ADDRESS
ARG VITE_WETH_ADDRESS
ARG VITE_WALLETCONNECT_PROJECT_ID
ARG VITE_TOKEN_LIST_URL

FROM node:20-alpine AS build
ARG VITE_RPC_URL
ARG VITE_ROUTER_ADDRESS
ARG VITE_TOKEN_IN_ADDRESS
ARG VITE_TOKEN_OUT_ADDRESS
ARG VITE_WETH_ADDRESS
ARG VITE_WALLETCONNECT_PROJECT_ID
ARG VITE_TOKEN_LIST_URL
ENV VITE_RPC_URL=$VITE_RPC_URL
ENV VITE_ROUTER_ADDRESS=$VITE_ROUTER_ADDRESS
ENV VITE_TOKEN_IN_ADDRESS=$VITE_TOKEN_IN_ADDRESS
ENV VITE_TOKEN_OUT_ADDRESS=$VITE_TOKEN_OUT_ADDRESS
ENV VITE_WETH_ADDRESS=$VITE_WETH_ADDRESS
ENV VITE_WALLETCONNECT_PROJECT_ID=$VITE_WALLETCONNECT_PROJECT_ID
ENV VITE_TOKEN_LIST_URL=$VITE_TOKEN_LIST_URL

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

RUN npm run build

FROM nginx:stable-alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
